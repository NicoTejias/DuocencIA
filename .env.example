# Convex Configuration
VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# Google Drive Integration (for document uploads)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_API_KEY=your-google-api-key

# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key

# Firebase (Push Notifications)
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Firebase VAPID Key (for Web Push Notifications)
# Get this from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
VITE_FIREBASE_VAPID_KEY=your-vapid-public-key

# Firebase Measurement ID (optional, for analytics)
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Gemini AI (for quiz generation and evaluation)
GEMINI_API_KEY=your-gemini-api-key
